alias c='clear'
alias del='rm -rf'
alias drc='docker rm -v -f $(docker ps -qa)'
alias dri='docker rmi -f $(docker images -aq)'
alias gad='git add .'
alias gbr='git branch'
alias gcm='git commit -m'
alias gco='git checkout -b'
alias gfo='git fetch origin'
alias glo='git log'
alias gpl-this='git pull origin $(git rev-parse --abbrev-ref HEAD)'
alias gpl='git pull origin'
alias gps-this='git push origin $(git rev-parse --abbrev-ref HEAD)'
alias gps='git push origin'
alias gst='git status'
alias gsw='git switch'
alias l='ls -lhaS'
